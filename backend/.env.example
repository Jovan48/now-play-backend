# Example environment variables for the backend
# Copy to `.env` and adjust values before running

# Django
DJANGO_SECRET_KEY=replace-me-with-a-secure-secret
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: superuser to create during setup script
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=changeme123

# Staticfiles storage override (optional)
#DJANGO_STATICFILES_STORAGE=whitenoise.storage.CompressedManifestStaticFilesStorage
